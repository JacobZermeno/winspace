<UserControl x:Class="Winspace.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Winspace.Helpers"
             Background="{DynamicResource CanvasBrush}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolVis"/>
        <helpers:InverseBoolConverter x:Key="InvBool"/>
        <helpers:NullToVisibilityConverter x:Key="NullVis"/>
        <helpers:StringEqualsConverter x:Key="StrEq"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{DynamicResource NavBrush}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="CONFIGURATION"
                               Foreground="{DynamicResource ForegroundBrush}"
                               FontFamily="{StaticResource MetroFont}"
                               FontSize="{StaticResource FontSizeLarge}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Profile selector -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Profile:"
                               Style="{StaticResource SubtleText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox Style="{StaticResource MetroComboBox}"
                              Width="130"
                              ItemsSource="{Binding ProfileNames}"
                              SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding AddProfileCommand}"
                            ToolTip="New Profile"
                            Margin="6,0,0,0" Padding="6,4">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource IconAdd}" Fill="{DynamicResource ForegroundBrush}" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding RemoveProfileCommand}"
                            ToolTip="Delete Profile"
                            Margin="10,0,0,0" Padding="6,4">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource IconDelete}" Fill="{DynamicResource DangerBrush}" Stretch="Uniform"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab pages -->
        <TabControl Grid.Row="1"
                    Style="{StaticResource MetroTabControl}">

            <!-- ══════════════════════════════════════════════════════
                 TAB 1: LAUNCH LIST
            ══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource MetroTabItem}" Header="LAUNCH LIST">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add entry form -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource TileBrush}"
                            Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="ADD APPLICATION" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Name"
                                       Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Style="{StaticResource MetroTextBox}"
                                     Text="{Binding NewLaunchName, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Display name (optional)"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Path"
                                       Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Grid Grid.Row="4" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource MetroTextBox}"
                                         Text="{Binding NewLaunchPath, UpdateSourceTrigger=PropertyChanged}"
                                         Tag="C:\path\to\app.exe or command"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding BrowseLaunchPathCommand}"
                                        Margin="6,0,0,0" ToolTip="Browse">
                                    <Viewbox Width="14" Height="14">
                                        <Path Data="{StaticResource IconFolder}" Fill="{DynamicResource ForegroundBrush}" Stretch="Uniform"/>
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <Button Grid.Row="6" Grid.ColumnSpan="2"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding AddLaunchEntryCommand}"
                                    HorizontalAlignment="Right"
                                    Padding="20,8">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                        <Path Data="{StaticResource IconAdd}" Fill="White" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="ADD TO LAUNCH LIST"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- List -->
                    <ListBox Grid.Row="1"
                             Style="{StaticResource MetroListBox}"
                             ItemContainerStyle="{StaticResource MetroListBoxItem}"
                             ItemsSource="{Binding LaunchList}"
                             SelectedItem="{Binding SelectedLaunchEntry, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="{StaticResource FontSizeNormal}"/>
                                        <TextBlock Text="{Binding Path}"
                                                   Style="{StaticResource SubtleText}"/>
                                        <TextBlock Text="{Binding Arguments}"
                                                   Style="{StaticResource SubtleText}"
                                                   Visibility="{Binding Arguments, Converter={StaticResource NullVis}}"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{DynamicResource AccentBrush}"
                                            Width="3" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Remove button -->
                    <Button Grid.Row="2"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveLaunchEntryCommand}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0" Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconDelete}" Fill="White" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="REMOVE SELECTED"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 2: KILL LIST
            ══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource MetroTabItem}" Header="KILL LIST">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left: running processes -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="RUNNING PROCESSES" Style="{StaticResource SectionHeader}"/>
                    <Grid Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButton}"
                                Command="{Binding RefreshRunningProcessesCommand}"
                                ToolTip="Refresh">
                            <Viewbox Width="14" Height="14">
                                <Path Data="{StaticResource IconRefresh}" Fill="{DynamicResource SubtleBrush}" Stretch="Uniform"/>
                            </Viewbox>
                        </Button>
                    </Grid>
                    <ListBox Grid.Row="1" Grid.Column="0"
                             Style="{StaticResource MetroListBox}"
                             ItemContainerStyle="{StaticResource MetroListBoxItem}"
                             ItemsSource="{Binding RunningProcesses}"
                             SelectedItem="{Binding SelectedRunningProcess, Mode=TwoWay}"/>
                    <Button Grid.Row="2" Grid.Column="0"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding AddToKillListCommand}"
                            Margin="0,8,0,0" Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconAdd}" Fill="White" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="ADD TO KILL LIST"/>
                        </StackPanel>
                    </Button>

                    <!-- Right: kill list -->
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="WILL BE CLOSED ON ACTIVATE" Style="{StaticResource SectionHeader}"/>
                    <ListBox Grid.Row="1" Grid.Column="2"
                             Style="{StaticResource MetroListBox}"
                             ItemContainerStyle="{StaticResource MetroListBoxItem}"
                             ItemsSource="{Binding KillList}"
                             SelectedItem="{Binding SelectedKillEntry, Mode=TwoWay}"/>
                    <Button Grid.Row="2" Grid.Column="2"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveFromKillListCommand}"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0" Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="12" Height="12" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconDelete}" Fill="White" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="REMOVE"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 3: WHITELIST
            ══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource MetroTabItem}" Header="WHITELIST">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- System whitelist (read-only) -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="SYSTEM PROTECTED (READ-ONLY)" Style="{StaticResource SectionHeader}"/>
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="{DynamicResource InputBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <ItemsControl ItemsSource="{Binding SystemWhitelist}"
                                      IsHitTestVisible="False"
                                      Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               FontFamily="{StaticResource MetroFont}"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               Padding="10,5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                    </Border>
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="These processes are always protected."
                               Style="{StaticResource SubtleText}"
                               Margin="0,8,0,0"/>

                    <!-- User whitelist -->
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="USER PROTECTED" Style="{StaticResource SectionHeader}"/>
                    <ListBox Grid.Row="1" Grid.Column="2"
                             Style="{StaticResource MetroListBox}"
                             ItemContainerStyle="{StaticResource MetroListBoxItem}"
                             ItemsSource="{Binding UserWhitelist}"
                             SelectedItem="{Binding SelectedWhitelistEntry, Mode=TwoWay}"/>
                    <Grid Grid.Row="2" Grid.Column="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource MetroTextBox}"
                                 Text="{Binding NewWhitelistEntry, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Process name (e.g. spotify)"/>
                        <Button Grid.Column="2"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding AddWhitelistEntryCommand}"
                                Padding="14,8">
                            <TextBlock Text="PROTECT"/>
                        </Button>
                        <Button Grid.Column="4"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding RemoveWhitelistEntryCommand}"
                                Padding="14,8">
                            <TextBlock Text="REMOVE"/>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 4: LAYOUT
            ══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource MetroTabItem}" Header="LAYOUT">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Preset picker -->
                    <Border Grid.Row="0" Background="{DynamicResource TileBrush}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="BUILT-IN PRESETS" Style="{StaticResource SectionHeader}"/>
                            <ComboBox Grid.Row="2"
                                      Style="{StaticResource MetroComboBox}"
                                      ItemsSource="{Binding LayoutPresetNames}"
                                      SelectedItem="{Binding SelectedPresetName, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <Separator Grid.Row="1"/>

                    <!-- Capture custom layout -->
                    <Border Grid.Row="2" Background="{DynamicResource TileBrush}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="CAPTURE CURRENT LAYOUT" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Grid.Row="2"
                                       Text="Arrange your launch list apps on screen, then click Capture to save their positions."
                                       Style="{StaticResource SubtleText}"
                                       TextWrapping="Wrap"/>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding CaptureLayoutCommand}"
                                        Padding="20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                            <Path Data="{StaticResource IconCapture}" Fill="White" Stretch="Uniform"/>
                                        </Viewbox>
                                        <TextBlock Text="CAPTURE LAYOUT"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LayoutStatusMessage}"
                                           Style="{StaticResource SubtleText}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Preset visual tiles -->
                    <TextBlock Grid.Row="4" Text="PRESET PREVIEWS" Style="{StaticResource SectionHeader}"/>
                    <ScrollViewer Grid.Row="5">
                        <WrapPanel Orientation="Horizontal">
                            <!-- 50/50 Split -->
                            <Border Width="120" Height="80" Background="{DynamicResource TileBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,8" ToolTip="50/50 Split Screen">
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" Opacity="0.5"/>
                                    <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>
                                    <Rectangle Grid.Column="2" Fill="{DynamicResource AccentBrush}" Opacity="0.3"/>
                                </Grid>
                            </Border>
                            <!-- Three-column -->
                            <Border Width="120" Height="80" Background="{DynamicResource TileBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,8" ToolTip="Three-Column Grid">
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" Opacity="0.5"/>
                                    <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>
                                    <Rectangle Grid.Column="2" Fill="{DynamicResource AccentBrush}" Opacity="0.5"/>
                                    <Rectangle Grid.Column="3" Fill="{DynamicResource BorderBrush}"/>
                                    <Rectangle Grid.Column="4" Fill="{DynamicResource AccentBrush}" Opacity="0.3"/>
                                </Grid>
                            </Border>
                            <!-- Primary Center -->
                            <Border Width="120" Height="80" Background="{DynamicResource TileBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,8" ToolTip="Primary Center Focus">
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" Opacity="0.3"/>
                                    <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>
                                    <Rectangle Grid.Column="2" Fill="{DynamicResource AccentBrush}" Opacity="0.7"/>
                                    <Rectangle Grid.Column="3" Fill="{DynamicResource BorderBrush}"/>
                                    <Rectangle Grid.Column="4" Fill="{DynamicResource AccentBrush}" Opacity="0.3"/>
                                </Grid>
                            </Border>
                            <!-- Full Screen -->
                            <Border Width="120" Height="80" Background="{DynamicResource TileBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,8,8" ToolTip="Full Screen">
                                <Rectangle Margin="6" Fill="{DynamicResource AccentBrush}" Opacity="0.7"/>
                            </Border>
                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════
                 TAB 5: THEME
            ══════════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource MetroTabItem}" Header="THEME">
                <ScrollViewer Margin="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">

                        <!-- Accent color -->
                        <Border Background="{DynamicResource TileBrush}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ACCENT COLOR" Style="{StaticResource SectionHeader}"/>
                                <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <RadioButton GroupName="Accent" Content="Cobalt" Margin="0,0,12,8"
                                                 IsChecked="{Binding SelectedAccent, Mode=TwoWay,
                                                             Converter={StaticResource StrEq}, ConverterParameter=Cobalt}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 FontFamily="{StaticResource MetroFont}"/>
                                    <RadioButton GroupName="Accent" Content="Crimson" Margin="0,0,12,8"
                                                 IsChecked="{Binding SelectedAccent, Mode=TwoWay,
                                                             Converter={StaticResource StrEq}, ConverterParameter=Crimson}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 FontFamily="{StaticResource MetroFont}"/>
                                    <RadioButton GroupName="Accent" Content="Teal" Margin="0,0,12,8"
                                                 IsChecked="{Binding SelectedAccent, Mode=TwoWay,
                                                             Converter={StaticResource StrEq}, ConverterParameter=Teal}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 FontFamily="{StaticResource MetroFont}"/>
                                    <RadioButton GroupName="Accent" Content="Emerald" Margin="0,0,12,8"
                                                 IsChecked="{Binding SelectedAccent, Mode=TwoWay,
                                                             Converter={StaticResource StrEq}, ConverterParameter=Emerald}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 FontFamily="{StaticResource MetroFont}"/>
                                </WrapPanel>
                                <!-- Accent color selector combo (primary binding) -->
                                <ComboBox Style="{StaticResource MetroComboBox}"
                                          ItemsSource="{Binding AccentColorNames}"
                                          SelectedItem="{Binding SelectedAccent, Mode=TwoWay}"
                                          Margin="0,8,0,0" Width="160" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Dark / Light mode -->
                        <Border Background="{DynamicResource TileBrush}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>
                                <CheckBox Style="{StaticResource MetroToggle}"
                                          IsChecked="{Binding DarkMode, Mode=TwoWay}"
                                          Content="Dark Mode"
                                          Margin="0,8,0,0"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          FontFamily="{StaticResource MetroFont}"/>
                            </StackPanel>
                        </Border>

                        <!-- View mode -->
                        <Border Background="{DynamicResource TileBrush}" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="LIST VIEW MODE" Style="{StaticResource SectionHeader}"/>
                                <ComboBox Style="{StaticResource MetroComboBox}"
                                          ItemsSource="{Binding ViewModeNames}"
                                          SelectedItem="{Binding SelectedViewMode, Mode=TwoWay}"
                                          Width="160" HorizontalAlignment="Left"
                                          Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
