<Window x:Class="Winspace.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Winspace.Views"
        xmlns:vm="clr-namespace:Winspace.ViewModels"
        xmlns:helpers="clr-namespace:Winspace.Helpers"
        Title="Winspace"
        Width="820" Height="580"
        MinWidth="640" MinHeight="420"
        WindowStyle="None"
        Background="{DynamicResource CanvasBrush}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <!-- Eliminates the 1 px DWM white-frame artifact that appears when
         WindowStyle=None is used without AllowsTransparency. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      CornerRadius="0"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- Outer border: sharp Metro frame -->
    <Border Background="{DynamicResource CanvasBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Title bar ─────────────────────────────────────── -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource NavBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                            <Path Data="{StaticResource IconLayout}"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Uniform"/>
                        </Viewbox>
                        <TextBlock Text="WINSPACE"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontFamily="{StaticResource MetroFont}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls — fixed 46 × 38 px tiles, flush to edge like Windows -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButton}"
                                Click="MinimizeToTray_Click"
                                Width="46" Height="38"
                                ToolTip="Minimize to tray">
                            <TextBlock Text="—" Foreground="{DynamicResource SubtleBrush}" FontSize="13"/>
                        </Button>
                        <!-- Maximize / Restore — icon swaps based on WindowState -->
                        <Button Style="{StaticResource GhostButton}"
                                Click="MaximizeRestore_Click"
                                Width="46" Height="38"
                                ToolTip="Maximize / Restore">
                            <Viewbox Width="13" Height="13">
                                <Path Fill="{DynamicResource SubtleBrush}" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource IconMaximize}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WindowState,
                                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                                             Value="Maximized">
                                                    <Setter Property="Data" Value="{StaticResource IconRestore}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                        </Button>
                        <!-- Close: hovers DangerBrush (red) instead of accent -->
                        <Button Width="46" Height="38" ToolTip="Close"
                                Click="CloseWindow_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="✕" Foreground="{DynamicResource SubtleBrush}" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Left nav sidebar ──────────────────────────────── -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{DynamicResource NavBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel>
                    <Button Command="{Binding NavigateDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardView}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,10,0">
                                <Path Data="{StaticResource IconDashboard}" Fill="{DynamicResource ForegroundBrush}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="DASHBOARD"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateConfigCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfigView}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,10,0">
                                <Path Data="{StaticResource IconSettings}" Fill="{DynamicResource ForegroundBrush}" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="SETTINGS"/>
                        </StackPanel>
                    </Button>

                    <Separator/>

                    <!-- Quick-status tile in sidebar -->
                    <Border Margin="12" Background="{DynamicResource TileBrush}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="STATUS"
                                       Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{Binding Dashboard.ToggleLabel}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontFamily="{StaticResource MetroFont}"
                                       FontSize="{StaticResource FontSizeNormal}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Dashboard.ActiveProfileName}"
                                       Style="{StaticResource SubtleText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Main content area with view transition ────────── -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="{DynamicResource CanvasBrush}"
                    ClipToBounds="True">

                <!-- Visibility reads IsDashboardView/IsConfigView from the
                     Window's DataContext (MainViewModel) via RelativeSource
                     so the child-VM DataContext override doesn't break it. -->
                <Grid>
                    <views:DashboardView x:Name="DashView"
                                         DataContext="{Binding Dashboard}"
                                         Visibility="{Binding DataContext.IsDashboardView,
                                                              RelativeSource={RelativeSource AncestorType=Window},
                                                              Converter={StaticResource BoolVis}}">
                        <views:DashboardView.RenderTransform>
                            <TranslateTransform/>
                        </views:DashboardView.RenderTransform>
                    </views:DashboardView>

                    <views:ConfigView x:Name="CfgView"
                                      DataContext="{Binding Config}"
                                      Visibility="{Binding DataContext.IsConfigView,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           Converter={StaticResource BoolVis}}">
                        <views:ConfigView.RenderTransform>
                            <TranslateTransform/>
                        </views:ConfigView.RenderTransform>
                    </views:ConfigView>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
