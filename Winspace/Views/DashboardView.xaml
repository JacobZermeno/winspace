<UserControl x:Class="Winspace.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Winspace.Helpers"
             Background="{DynamicResource CanvasBrush}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Center content -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Profile label -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                <TextBlock Text="ACTIVE PROFILE"
                           Style="{StaticResource SectionHeader}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveProfileName}"
                           Foreground="{DynamicResource ForegroundBrush}"
                           FontFamily="{StaticResource MetroFont}"
                           FontSize="{StaticResource FontSizeLarge}"
                           FontWeight="Light"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Toggle tile — Border instead of Button removes all
                 WPF command/template machinery from the hit-test path. -->
            <Border x:Name="ToggleTile"
                    Width="220" Height="220"
                    Cursor="Hand"
                    MouseLeftButtonDown="ToggleTile_MouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource TileBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Viewbox Width="52" Height="52" Margin="0,0,0,10">
                        <Path Data="{StaticResource IconPower}"
                              Fill="White"
                              Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="{Binding ToggleLabel}"
                               FontFamily="{StaticResource MetroFont}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Sub-label / live status below the tile -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontFamily="{StaticResource MetroFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="280"
                       Margin="0,12,0,0"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>

            <TextBlock Text="{Binding ToggleSubLabel}"
                       Style="{StaticResource SubtleText}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

        </StackPanel>

        <!-- Error banner — visible only when there's an error message and NOT busy -->
        <Border Grid.Row="1"
                Background="{DynamicResource DangerBrush}"
                Padding="16,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontFamily="{StaticResource MetroFont}"
                       FontSize="{StaticResource FontSizeNormal}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Bottom status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource NavBrush}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource SubtleText}"
                           VerticalAlignment="Center"/>
                <!-- Pulsing busy dots -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                    <Ellipse x:Name="Dot1" Width="5" Height="5" Margin="2,0"
                             Fill="{DynamicResource AccentBrush}"/>
                    <Ellipse x:Name="Dot2" Width="5" Height="5" Margin="2,0"
                             Fill="{DynamicResource AccentBrush}" Opacity="0.6"/>
                    <Ellipse x:Name="Dot3" Width="5" Height="5" Margin="2,0"
                             Fill="{DynamicResource AccentBrush}" Opacity="0.3"/>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="Dot1"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.4" AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetName="Dot2"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.6" To="1" Duration="0:0:0.4" AutoReverse="True"
                                                     BeginTime="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="Dot3"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="0.7" Duration="0:0:0.4" AutoReverse="True"
                                                     BeginTime="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
